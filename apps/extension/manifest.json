{
  "manifest_version": 3,
  "name": "haGIT",
  "version": "1.0.0",
  "description": "Quick habit commits and management for haGIT",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://hagithub.vercel.app/*",
    "http://localhost:*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "haGIT"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
