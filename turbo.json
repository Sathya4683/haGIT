{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "dist/**"
            ],
            "env": [
                "DATABASE_URL",
                "JWT_SECRET"
            ]
        },
        "dev": {
            "cache": false
        }
    }
}
